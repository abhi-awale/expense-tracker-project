<section class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-lg-5">
        <span class="badge text-bg-success mb-3">Secure reset</span>
        <h1 class="h3 fw-bold mb-2">Set a new password</h1>
        <p class="text-secondary mb-4">Choose a strong password with at least 8 characters.</p>
        <form method="post" action="/auth/reset-password/<%= token %>" class="row g-3">
          <%- include('../partials/csrf-field') %>
          <div class="col-md-6">
            <label class="form-label">New password</label>
            <input name="password" type="password" class="form-control" />
            <% if (validationErrors.password) { %><div class="form-error"><%= validationErrors.password %></div><% } %>
          </div>
          <div class="col-md-6">
            <label class="form-label">Confirm password</label>
            <input name="confirmPassword" type="password" class="form-control" />
            <% if (validationErrors.confirmPassword) { %><div class="form-error"><%= validationErrors.confirmPassword %></div><% } %>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary btn-lg">Reset password</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
