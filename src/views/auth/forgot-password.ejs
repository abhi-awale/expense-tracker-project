<section class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-lg-5">
        <span class="badge text-bg-warning mb-3">Recover access</span>
        <h1 class="h3 fw-bold mb-2">Forgot your password?</h1>
        <p class="text-secondary mb-4">Enter your email address and we’ll generate a reset link for your account.</p>
        <form method="post" action="/auth/forgot-password" class="vstack gap-3">
          <%- include('../partials/csrf-field') %>
          <div>
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control" value="<%= oldInput.email || '' %>" />
            <% if (validationErrors.email) { %><div class="form-error"><%= validationErrors.email %></div><% } %>
          </div>
          <button type="submit" class="btn btn-primary btn-lg">Send reset link</button>
          <p class="mb-0 text-secondary"><a href="/auth/login">Back to login</a></p>
        </form>
      </div>
    </div>
  </div>
</section>
