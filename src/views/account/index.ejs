<section class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
  <div>
    <h1 class="h3 fw-bold mb-1">Account settings</h1>
    <p class="text-secondary mb-0">Keep your profile details current and rotate your password when needed.</p>
  </div>
</section>

<section class="card border-0 shadow-sm mb-4 premium-hero">
  <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
    <div>
      <div class="small text-uppercase text-secondary fw-semibold mb-2">Billing</div>
      <h2 class="h4 mb-1"><%= accountUser.isPremium ? 'Premium is active' : 'Upgrade to premium' %></h2>
      <p class="mb-0 text-secondary">
        <% if (accountUser.isPremium) { %>
          Active since <%= new Date(accountUser.premiumActivatedAt).toLocaleDateString('en-IN') %>. Report exports and custom categories are unlocked.
        <% } else { %>
          Unlock report exports in PDF/SVG and create custom categories for INR <%= premiumPrice %>.
        <% } %>
      </p>
    </div>
    <% if (accountUser.isPremium) { %>
      <span class="badge text-bg-success px-3 py-2">Premium active</span>
    <% } else { %>
      <button
        type="button"
        class="btn btn-primary js-premium-upgrade"
        data-plan="premium"
      >
        Upgrade with Cashfree
      </button>
    <% } %>
  </div>
</section>

<section class="row g-4">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <h2 class="h5 mb-3">Profile details</h2>
        <form method="post" action="/account/profile" class="vstack gap-3">
          <%- include('../partials/csrf-field') %>
          <div>
            <label class="form-label">Name</label>
            <input name="name" class="form-control" value="<%= oldInput.name || accountUser.name %>" />
            <% if (validationErrors.name) { %><div class="form-error"><%= validationErrors.name %></div><% } %>
          </div>
          <div>
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control" value="<%= oldInput.email || accountUser.email %>" />
            <% if (validationErrors.email) { %><div class="form-error"><%= validationErrors.email %></div><% } %>
          </div>
          <div class="text-secondary small">Member since <%= new Date(accountUser.createdAt).toLocaleDateString('en-IN') %></div>
          <button type="submit" class="btn btn-primary">Save profile</button>
        </form>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <h2 class="h5 mb-3">Change password</h2>
        <form method="post" action="/account/password" class="vstack gap-3">
          <%- include('../partials/csrf-field') %>
          <div>
            <label class="form-label">Current password</label>
            <input name="currentPassword" type="password" class="form-control" />
            <% if (validationErrors.currentPassword) { %><div class="form-error"><%= validationErrors.currentPassword %></div><% } %>
          </div>
          <div>
            <label class="form-label">New password</label>
            <input name="newPassword" type="password" class="form-control" />
            <% if (validationErrors.newPassword) { %><div class="form-error"><%= validationErrors.newPassword %></div><% } %>
          </div>
          <div>
            <label class="form-label">Confirm new password</label>
            <input name="confirmNewPassword" type="password" class="form-control" />
            <% if (validationErrors.confirmNewPassword) { %><div class="form-error"><%= validationErrors.confirmNewPassword %></div><% } %>
          </div>
          <button type="submit" class="btn btn-outline-primary">Update password</button>
        </form>
      </div>
    </div>
  </div>
</section>
