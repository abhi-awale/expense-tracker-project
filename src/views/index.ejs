<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/index.css">
    <title>Document</title>
</head>

<body>
    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
    <div class="blob blob3"></div>

    <div class="wrapper">
        <div class="landing">
            <!-- Navbar -->
            <nav class="navbar">
                <h1 class="logo">Xpense</h1>

                <button onclick="window.location='/login'" class="nav-btn">
                    Login
                </button>
            </nav>

            <!-- Hero Section -->
            <section class="hero">
                <div class="hero-text">
                    <h2>Track Your Expenses Effortlessly</h2>
                    <p>
                        Manage your daily spending, visualize your finances, and stay in control
                        with a modern expense tracker.
                    </p>
                    <div class="hero-actions">
                        <button class="primary-btn"
                            onclick="window.location='/login'">
                            Get Started
                        </button>
                        <!-- <button class="secondary-btn">Demo</button> -->
                    </div>
                </div>

                <!-- Glass Card Preview -->
                <div class="preview-card">
                    <h3>Monthly Overview</h3>

                    <div class="balance">
                        <p>Total Balance</p>
                        <h2>₹ 24,500</h2>
                    </div>

                    <div class="stats">
                        <div>
                            <p>Income</p>
                            <span class="income">+ ₹ 40,000</span>
                        </div>
                        <div>
                            <p>Expense</p>
                            <span class="expense">- ₹ 15,500</span>
                        </div>
                    </div>

                    <div class="transactions">
                        <p>Recent</p>
                        <ul>
                            <li>🍔 Food <span>- ₹250</span></li>
                            <li>🚕 Travel <span>- ₹600</span></li>
                            <li>💼 Salary <span>+ ₹40,000</span></li>
                        </ul>
                    </div>
                </div>
            </section>

            <section class="features reveal">
                <h2 class="section-title">Powerful Features</h2>
                <p class="section-subtitle">
                    Everything you need to manage your finances efficiently
                </p>

                <div class="feature-grid">

                    <div class="feature-card">
                        <div class="icon">📊</div>
                        <h3>Smart Tracking</h3>
                        <p>Automatically categorize and monitor your daily expenses.</p>
                    </div>

                    <div class="feature-card">
                        <div class="icon">⚡</div>
                        <h3>Real-Time Insights</h3>
                        <p>Visualize spending patterns with instant analytics.</p>
                    </div>

                    <div class="feature-card">
                        <div class="icon">🎯</div>
                        <h3>Budget Goals</h3>
                        <p>Set monthly limits and achieve your savings targets.</p>
                    </div>

                    <div class="feature-card">
                        <div class="icon">🔐</div>
                        <h3>Secure & Private</h3>
                        <p>Your financial data stays protected with encryption.</p>
                    </div>

                </div>
            </section>

            <section class="how-it-works">
                <h2 class="section-title">How It Works</h2>
                <p class="section-subtitle">
                    Start tracking your finances in just a few simple steps
                </p>

                <div class="steps">

                    <div class="step-card">
                        <div class="step-number">01</div>
                        <h3>Add Expenses</h3>
                        <p>Quickly log your daily income and expenses with ease.</p>
                    </div>

                    <div class="step-card">
                        <div class="step-number">02</div>
                        <h3>Analyze Spending</h3>
                        <p>Get clear insights into where your money is going.</p>
                    </div>

                    <div class="step-card">
                        <div class="step-number">03</div>
                        <h3>Save & Grow</h3>
                        <p>Control your budget and improve your financial habits.</p>
                    </div>

                </div>
            </section>

            <section class="testimonials">
                <h2 class="section-title">What Users Say</h2>
                <p class="section-subtitle">
                    Trusted by people managing their finances smarter
                </p>

                <div class="testimonial-grid">

                    <div class="testimonial-card">
                        <div class="user">
                            <img src="https://i.pravatar.cc/100?img=12" alt="user">
                            <div>
                                <h4>Rahul Sharma</h4>
                                <span>Software Engineer</span>
                            </div>
                        </div>

                        <p class="review">
                            “Clean UI, fast performance, and super helpful insights. This app
                            changed how I track my spending.”
                        </p>
                    </div>

                    <div class="testimonial-card">
                        <div class="user">
                            <img src="https://i.pravatar.cc/100?img=32" alt="user">
                            <div>
                                <h4>Sneha Patil</h4>
                                <span>Freelancer</span>
                            </div>
                        </div>

                        <p class="review">
                            “I finally started saving money consistently. Budget tracking is
                            incredibly simple here.”
                        </p>
                    </div>

                    <div class="testimonial-card">
                        <div class="user">
                            <img src="https://i.pravatar.cc/100?img=45" alt="user">
                            <div>
                                <h4>Amit Verma</h4>
                                <span>Entrepreneur</span>
                            </div>
                        </div>

                        <p class="review">
                            “Real-time analytics and smooth UX. Feels like a premium product.”
                        </p>
                    </div>

                </div>
            </section>

            <section class="stats-section">
                <div class="stats-container">

                    <div class="stat-card">
                        <h3>10K+</h3>
                        <p>Active Users</p>
                    </div>

                    <div class="stat-card">
                        <h3>₹50L+</h3>
                        <p>Money Tracked</p>
                    </div>

                    <div class="stat-card">
                        <h3>4.8★</h3>
                        <p>User Rating</p>
                    </div>

                    <div class="stat-card">
                        <h3>99.9%</h3>
                        <p>Uptime</p>
                    </div>

                </div>
            </section>

            <section class="pricing">
                <h2 class="section-title">Choose Your Plan</h2>
                <p class="section-subtitle">
                    Start free. Upgrade when you need deeper insights.
                </p>

                <div class="pricing-grid">

                    <!-- FREE -->
                    <div class="pricing-card free">
                        <h3>Free</h3>
                        <p class="price">₹0</p>

                        <ul>
                            <li>Unlimited expense insertion</li>
                            <li>Pre-defined categories</li>
                            <li>Basic dashboard insights</li>
                        </ul>

                        <button class="secondary-btn">Start Free</button>
                    </div>

                    <!-- PREMIUM (CENTER FOCUS) -->
                    <div class="pricing-card premium">
                        <div class="glow"></div>

                        <div class="badge">🔥 Most Popular</div>

                        <h3>Premium</h3>
                        <p class="price">₹199 <span>/month</span></p>

                        <ul>
                            <li>Unlimited expense insertion</li>
                            <li>Custom categories</li>
                            <li>Advanced analytics dashboard</li>
                            <li>AI financial reports</li>
                            <li>Export data</li>
                            <li>Unlimited history</li>
                        </ul>

                        <button class="primary-btn">Upgrade Now</button>
                    </div>

                </div>
            </section>

            <section class="faq">
                <h2 class="section-title">Frequently Asked Questions</h2>
                <p class="section-subtitle">
                    Everything you need to know about Xpense
                </p>

                <div class="faq-container">

                    <div class="faq-item">
                        <button class="faq-question">
                            Is my data secure?
                            <span>+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Your data is encrypted and securely stored with industry standards.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <button class="faq-question">
                            Is Xpense free to use?
                            <span>+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes, core features are free. Premium features may be added later.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <button class="faq-question">
                            Can I track multiple accounts?
                            <span>+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes, you can manage multiple income sources and expense categories.</p>
                        </div>
                    </div>

                </div>
            </section>

            <section class="cta">
                <div class="cta-box">
                    <h2>Take Control of Your Finances Today</h2>
                    <p>
                        Start tracking your expenses, set budgets, and build better financial habits.
                    </p>

                    <div class="cta-actions">
                        <button class="primary-btn" onclick="window.location='register.html'">
                            Get Started Free
                        </button>
                        <!-- <button class="secondary-btn">
                            View Demo
                        </button> -->
                    </div>
                </div>
            </section>

            <!-- FOOTER -->
            <footer class="footer">
                <p>© 2026 Xpense. All rights reserved.</p>
            </footer>

        </div>
    </div>

    <script src="/js/script.js"></script>
</body>

</html>