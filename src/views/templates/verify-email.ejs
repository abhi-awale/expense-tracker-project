<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
</head>

<body style="margin:0; padding:0; background-color:#f4f6f8; font-family: Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="padding:20px;">
    <tr>
      <td align="center">

        <!-- Card -->
        <table width="100%" max-width="500px" cellpadding="0" cellspacing="0"
          style="background:#ffffff; border-radius:10px; overflow:hidden; box-shadow:0 4px 10px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#6366f1,#8b5cf6); padding:25px; text-align:center;">

              <!-- Logo Typography -->
              <div style="font-size:22px; font-weight:bold; color:#ffffff; letter-spacing:1px;">
                Expense<span style="color:#c7d2fe;"></span>
              </div>
              <div style="font-size:12px; color:#c7d2fe;">
                Track smarter. Spend better.
              </div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:30px; color:#333;">

              <p style="margin:0 0 15px 0; font-size:16px;">
                Hello <strong><%= name %></strong>,
              </p>

              <p style="margin:0 0 20px 0; font-size:14px; color:#555;">
                Welcome to Expense. Please verify your email address to secure your account and stay updated.
              </p>

              <!-- Button -->
              <table cellpadding="0" cellspacing="0" style="margin:25px 0;">
                <tr>
                  <td align="center">
                    <a href="<%= link %>"
                      style="background:linear-gradient(135deg,#6366f1,#8b5cf6);
                             color:#ffffff;
                             padding:12px 24px;
                             border-radius:6px;
                             text-decoration:none;
                             font-weight:bold;
                             display:inline-block;">
                      Verify Email
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Fallback -->
              <p style="font-size:12px; color:#888;">
                If the button doesn’t work, copy and paste this link into your browser:
              </p>

              <p style="word-break:break-all; font-size:12px; color:#6366f1;">
                <%= link %>
              </p>

              <p style="margin-top:20px; font-size:12px; color:#999;">
                If you didn’t create an account, you can safely ignore this email.
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f9fafb; padding:15px; text-align:center; font-size:12px; color:#888;">
              © <%= new Date().getFullYear() %> Expense. All rights reserved.
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>